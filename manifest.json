{
  "manifest_version": 3,
  "name": "Smart Video Speed",
  "version": "1.8.0",
  "description": "Automatically speeds up silent parts of videos using real-time audio analysis.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "toggle-plugin": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Toggle Smart Video Speed on/off"
    },
    "cycle-mode": {
      "suggested_key": { "default": "Alt+Shift+M" },
      "description": "Cycle through speed modes (Comfort → Balanced → Turbo)"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://vimeo.com/*",
        "https://www.netflix.com/*",
        "https://*/*",
        "http://*/*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
